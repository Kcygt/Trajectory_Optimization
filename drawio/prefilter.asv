clc;
clear;
close all;

%% Time
dt = 0.01;
t = 0:dt:12;

%% Step levels
s1 = .1;
s2 = .25;
s3 = .4;

%% Step input
u = zeros(size(t));
u(t>=1) = s1;
u(t>=4) = s2;
u(t>=7) = s3;

%% Different filters for each step
tau1 = 1.2;   % slow
tau2 = 0.6;   % medium
tau3 = 0.25;  % fast

sys1 = tf(1,[tau1 1]);
sys2 = tf(1,[tau2 1]);
sys3 = tf(1,[tau3 1]);

%% Create signals for each step
u1 = zeros(size(t));
u2 = zeros(size(t));
u3 = zeros(size(t));

u1(t>=1) = s1;
u2(t>=4) = s2 - s1;
u3(t>=7) = s3 - s2;

%% Filter each step separately
y1 = lsim(sys1,u1,t);
y2 = lsim(sys2,u2,t);
y3 = lsim(sys3,u3,t);

%% Total output
y = y1 + y2 + y3;

%% Plot
figure
hold on
grid on

% Step inputs with different colors
stairs(t,u1,'LineWidth',3,'Color',[0 0.7 0])      % green
stairs(t,u1+u2,'LineWidth',3,'Color',[0 0 1])     % blue
stairs(t,u,'LineWidth',3,'Color',[1 0 0])         % red (final level)

% Output
plot(t,y,'k','LineWidth',2)

xlabel('Time')
ylabel('Joint position q')
title('Joint Step Input with Different Prefilter Shapes')

legend('Step 1','Step 2','Step 3','Prefiltered Output')